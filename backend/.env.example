# Database
DATABASE_URL=postgresql+asyncpg://liarsbar:liarsbar@localhost:5432/liarsbar

# SecondMe OAuth2
SECONDME_CLIENT_ID=your_client_id
SECONDME_CLIENT_SECRET=your_client_secret
